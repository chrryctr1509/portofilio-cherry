# Frontend environment example for Vite
# Vite exposes only variables prefixed with VITE_ to the client.
# Copy this file to `.env` (or `.env.local`) and restart the dev server.

# Base API URL used by the frontend to call the backend
# Example: http://localhost:8080
VITE_API_URL=http://localhost:8080

# Optional: frontend title or other client-only settings
VITE_APP_TITLE=Creative Hub